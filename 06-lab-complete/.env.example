# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
LLM_MODEL=mock-llm-v1

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=secret-key-123

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
MAX_HISTORY_TURNS=20
CONVERSATION_TTL_SECONDS=604800

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
